            <string notr="true">
             QFrame#formCard {
              background-color: white;
              border-radius: 15px;
              border: 1px solid #e0e0e0;
             }
             QLabel { color: #333; font-size: 14px; font-weight: bold; }
             QLineEdit, QComboBox, QSpinBox {
              padding: 10px; border: 1px solid #ccc; border-radius: 5px; font-size: 14px; background-color: #fafafa; color: black;
             }
             QLineEdit:focus, QComboBox:focus, QSpinBox:focus { border: 1px solid #3498db; background-color: white; }
             QPushButton#btn_modifier {
              background-color: #007bff; color: white; font-weight: bold; border-radius: 5px; padding: 12px; font-size: 14px;
             }
             QPushButton#btn_modifier:hover { background-color: #0069d9; }
             QPushButton#btn_annuler {
