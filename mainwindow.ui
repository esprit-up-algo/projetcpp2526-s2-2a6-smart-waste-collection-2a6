  <property name="styleSheet">
   <string notr="true">
/* Fenêtre */
QMainWindow, QWidget#centralwidget, QTabWidget::pane {
    background-color: #eff3f8;
    font-family: &quot;Segoe UI&quot;, &quot;Helvetica Neue&quot;, Arial;
    font-size: 10pt;
    color: #263238;
}

/* Onglets en haut (Dashboard, Ajout, Modifier) */
QTabBar::tab {
    background: #2b3a42;
    color: white;
    padding: 6px 16px;
    border: 1px solid #222e36;
}
QTabBar::tab:selected {
    background: #1976d2;
}
QTabBar::tab:hover {
    background: #1565c0;
}

/* Sidebar gauche */
#sideBar {
    background-color: #10243a;
    color: white;
}
#sideLogo {
    background-color: #0b1a2b;
}
QLabel#sideLogo {
    color: white;
}
QPushButton#sideMenuButton {
    text-align: left;
    padding: 8px 16px;
    color: #cbd3df;
    background: transparent;
    border: none;
    border-radius: 0;
}
QPushButton#sideMenuButton:hover {
    background-color: #173151;
}
QPushButton#sideMenuButton:checked {
    background-color: #1d4b7a;
    color: white;
}

/* Top bar */
#topBar {
    background-color: #3b6998;
    color: white;
}
#titleLabel, #userLabel {
    color: white;
}
#titleLabel {
    font-size: 12pt;
    font-weight: 600;
}
#userLabel {
    font-weight: 600;
}

/* Boutons notif / profil */
QPushButton#btnNotif, QPushButton#btnProfil {
    background-color: rgba(255, 255, 255, 0.2);
    border-radius: 4px;
    padding: 4px 10px;
    border: none;
    color: white;
}
QPushButton#btnNotif:hover, QPushButton#btnProfil:hover {
    background-color: rgba(255, 255, 255, 0.3);
}

/* Cartes (contenu blanc arrondi) */
QFrame#card, QFrame#rightSidebar, QFrame#cardAdd, QFrame#cardMod,
QFrame#panelStats, QFrame#panelPhotos {
    background-color: white;
    border-radius: 12px;
    border: 1px solid #dde3eb;
}

/* Labels de formulaire (texte noir lisible) */
QLabel.formLabel {
    color: #263238;
    font-weight: 600;
}

/* Champs (texte en noir) */
QLineEdit, QComboBox, QSpinBox, QDoubleSpinBox {
    background-color: #f7f9fc;
    border: 1px solid #cfd8dc;
    border-radius: 6px;
    padding: 4px 8px;
    color: #263238;
}
QLineEdit:focus, QComboBox:focus, QSpinBox:focus, QDoubleSpinBox:focus {
    border: 1px solid #3b6998;
    background-color: white;
}

/* TextEdits */
QTextEdit {
    background-color: #f7f9fc;
    border: 1px solid #cfd8dc;
    border-radius: 8px;
    padding: 6px 10px;
    color: #263238;
}

/* Table Dashboard */
QTableWidget {
    background-color: white;
    border: 1px solid #dce1e8;
    border-radius: 8px;
    gridline-color: #f0f0f0;
    selection-background-color: #e3f2fd;
    selection-color: #263238;
}
QHeaderView::section {
    background-color: #f5f7fb;
    padding: 6px;
    border: 1px solid #dde3eb;
    font-weight: 600;
    color: #263238;
}

/* Barre de filtre dashboard */
QLineEdit#searchInput {
    background-color: white;
    border: 1px solid #cfd8dc;
    border-radius: 6px;
    padding: 4px 8px;
}
QComboBox#cbSort {
    background-color: white;
    border: 1px solid #cfd8dc;
    border-radius: 6px;
    padding: 4px 8px;
}

/* Boutons généraux */
QPushButton {
    border-radius: 6px;
    padding: 6px 16px;
    border: 1px solid #1976d2;
    background-color: #1e88e5;
    color: white;
}
QPushButton:hover {
    background-color: #1565c0;
}

/* Boutons verts / gris (Enregistrer / Annuler) */
QPushButton#btnSave_Add, QPushButton#btnSave_Mod {
    background-color: #43a047;
    border-color: #43a047;
}
QPushButton#btnCancel_Add, QPushButton#btnCancel_Mod {
    background-color: #b0bec5;
    border-color: #b0bec5;
}

/* Stat cards droite Dashboard */
QFrame.statCard {
    background-color: #e3f2fd;
    border-radius: 8px;
    border: 1px solid #bbdefb;
}
QLabel.statValue {
    font-size: 16pt;
    font-weight: 700;
    color: #1565c0;
}
QLabel.statLabel {
    font-size: 10pt;
    color: #546e7a;
}
QFrame.alertCard {
    background-color: #ffebee;
    border-radius: 8px;
    border: 1px solid #ffcdd2;
}
QLabel.alertValue {
    font-size: 16pt;
    font-weight: 700;
    color: #c62828;
}

/* Sliders */
QSlider::groove:horizontal {
    background: #e0e0e0;
    height: 6px;
    border-radius: 3px;
}
QSlider::handle:horizontal {
    background: #3b6998;
    width: 14px;
    margin: -4px 0;
    border-radius: 7px;
}
QSlider::sub-page:horizontal {
    background: #64b5f6;
    border-radius: 3px;
}

/* Zone image Ajout / Modifier */
QLabel#lblImgPreview_Add, QLabel#lblImgPreview_Mod {
    background-color: #eceff1;
    border: 2px dashed #cfd8dc;
    border-radius: 12px;
    color: #90a4ae;
}

/* Badges Priorité, etc. */
QLabel#badgeHigh {
    background-color: #e53935;
    color: white;
    border-radius: 10px;
    padding: 2px 8px;
    font-size: 8pt;
}
