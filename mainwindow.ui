  <property name="styleSheet">
   <string notr="true">
    * { font-family: 'Segoe UI', Arial, sans-serif; }
    
    QMainWindow, QWidget#centralwidget, QTabWidget::pane {
        background-color: #eff3f8;
        border: none;
    }

    QWidget#verticalLayoutWidget_1, QWidget#verticalLayoutWidget_2, QWidget#verticalLayoutWidget_3, QWidget#verticalLayoutWidget_4 {
        background-color: #0f2c4f;
    }

    QWidget#verticalLayoutWidget_1 QPushButton, 
    QWidget#verticalLayoutWidget_2 QPushButton, 
    QWidget#verticalLayoutWidget_3 QPushButton,
    QWidget#verticalLayoutWidget_4 QPushButton {
        color: #cfd8dc;
        text-align: left;
        padding-left: 20px;
        height: 40px;
        border: none;
        font-size: 14px;
        background-color: transparent;
    }
    
    QWidget#verticalLayoutWidget_1 QPushButton:hover, 
    QWidget#verticalLayoutWidget_2 QPushButton:hover, 
    QWidget#verticalLayoutWidget_3 QPushButton:hover,
    QWidget#verticalLayoutWidget_4 QPushButton:hover {
        background-color: #1d4e89;
        color: white;
        border-left: 4px solid #4caf50;
    }
    
    QLabel#label_1, QLabel#label_2, QLabel#label_3, QLabel#label_4 {
        color: white; font-weight: bold; font-size: 18px; padding: 20px 0 20px 20px;
    }

    QWidget#horizontalLayoutWidget_1, QWidget#horizontalLayoutWidget_2, QWidget#horizontalLayoutWidget_3, QWidget#horizontalLayoutWidget_4 {
        background-color: #3b6998;
    }
    
    QLabel#lb_1, QLabel#lb_2, QLabel#lb_3, QLabel#lb_4, QLabel#user_1, QLabel#user_2, QLabel#user_3, QLabel#user_4 {
        color: white; font-weight: bold; font-size: 14px;
    }

    QWidget#horizontalLayoutWidget_1 QPushButton, 
    QWidget#horizontalLayoutWidget_2 QPushButton, 
    QWidget#horizontalLayoutWidget_3 QPushButton,
    QWidget#horizontalLayoutWidget_4 QPushButton {
        background-color: rgba(255, 255, 255, 0.2);
        color: white;
        border-radius: 4px;
        padding: 5px 15px;
        border: none;
    }

    QFrame#cardFrame {
        background-color: white; border-radius: 12px; border: 1px solid #dce1e8;
    }
    QFrame#cardFrame QLabel {
        color: #2c3e50; font-size: 13px; font-weight: 600; padding-bottom: 2px;
    }
    QLabel#lblCardTitle {
        font-size: 20px; font-weight: bold; color: #1a1a1a; margin-bottom: 10px;
    }
    QLineEdit, QComboBox {
        background-color: #f7f9fc; border: 1px solid #e1e4e8; border-radius: 6px; padding: 8px; color: #333;
    }
    QLineEdit:focus { border: 1px solid #3b6998; background-color: white; }
    
    QPushButton#btnSave { background-color: #4caf50; color: white; font-weight: bold; border-radius: 6px; }
    QPushButton#btnCancel { background-color: #90a4ae; color: white; font-weight: bold; border-radius: 6px; }

    QTableWidget {
        background-color: white;
        border: 1px solid #dce1e8;
        border-radius: 8px;
        gridline-color: #f0f0f0;
        selection-background-color: #e3f2fd;
        selection-color: #333;
    }
    QHeaderView::section {
        background-color: white;
        color: #333;
        font-weight: bold;
        border: none;
        border-bottom: 2px solid #3b6998;
        padding: 8px;
    }

    QFrame#rightSidebar {
        background-color: white; border-radius: 8px; border: 1px solid #dce1e8;
    }
    QLabel.sectionTitle {
        font-weight: bold; color: #0f2c4f; font-size: 13px; margin-bottom: 5px;
    }
    
    QPushButton.actionBtn {
        background-color: #f5f5f5; border: 1px solid #ddd; border-radius: 5px; padding: 10px; text-align: center; color: #333;
    }
    QPushButton.actionBtn:hover { background-color: #e0e0e0; }

    QLineEdit#searchInput { background-color: white; border: 1px solid #ccc; }
    QPushButton#btnAddProduct { background-color: #3b6998; color: white; font-weight: bold; border-radius: 4px; padding: 5px 15px; }
