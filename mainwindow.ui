  <property name="styleSheet">
   <string notr="true">
    /* GLOBAL FONTS &amp; SETTINGS */
    * { font-family: 'Segoe UI', Arial, sans-serif; }
    
    /* MAIN BACKGROUND */
    QMainWindow, QWidget#centralwidget, QTabWidget::pane {
        background-color: #eff3f8; /* Light professional grey-blue */
        border: none;
    }

    /* =========================
       SIDEBAR STYLING 
       (Applied to the container widgets in all 3 tabs)
       ========================= */
    QWidget#verticalLayoutWidget_1, QWidget#verticalLayoutWidget_2, QWidget#verticalLayoutWidget_3 {
        background-color: #0f2c4f; /* Deep Navy Blue */
    }

    /* Sidebar Buttons */
    QWidget#verticalLayoutWidget_1 QPushButton, 
    QWidget#verticalLayoutWidget_2 QPushButton, 
    QWidget#verticalLayoutWidget_3 QPushButton {
        color: #cfd8dc;
        text-align: left;
        padding-left: 20px;
        height: 40px;
        border: none;
        font-size: 14px;
        background-color: transparent;
    }
    
    /* Sidebar Button Hover Effect */
    QWidget#verticalLayoutWidget_1 QPushButton:hover, 
    QWidget#verticalLayoutWidget_2 QPushButton:hover, 
    QWidget#verticalLayoutWidget_3 QPushButton:hover {
        background-color: #1d4e89; /* Slightly lighter blue */
        color: white;
        border-left: 4px solid #4caf50; /* Green accent line */
    }
    
    /* Logo Label Styling */
    QLabel#label_1, QLabel#label_2, QLabel#label_3 {
        color: white;
        font-weight: bold;
        font-size: 18px;
        padding: 20px 0 20px 20px;
    }

    /* =========================
       TOP BAR STYLING 
       ========================= */
    QWidget#horizontalLayoutWidget_1, QWidget#horizontalLayoutWidget_2, QWidget#horizontalLayoutWidget_3 {
        background-color: #3b6998; /* Header Blue */
    }
    
    /* Top Bar Text */
    QLabel#lb_1, QLabel#lb_2, QLabel#lb_3, QLabel#user_1, QLabel#user_2, QLabel#user_3 {
        color: white;
        font-weight: bold;
        font-size: 14px;
    }

    /* Top Bar Buttons (Notification/Profile) */
    QWidget#horizontalLayoutWidget_1 QPushButton, 
    QWidget#horizontalLayoutWidget_2 QPushButton, 
    QWidget#horizontalLayoutWidget_3 QPushButton {
        background-color: rgba(255, 255, 255, 0.2);
        color: white;
        border-radius: 4px;
        padding: 5px 15px;
        border: none;
    }

    /* =========================
       TAB 3: MODIFIER CARD STYLING
       ========================= */
    QFrame#cardFrame {
        background-color: white;
        border-radius: 12px;
        border: 1px solid #dce1e8;
    }

    /* Labels inside card */
    QFrame#cardFrame QLabel {
        color: #2c3e50;
        font-size: 13px;
        font-weight: 600;
        padding-bottom: 2px;
    }
    
    /* Main Title inside card */
    QLabel#lblCardTitle {
        font-size: 20px;
        font-weight: bold;
        color: #1a1a1a;
        margin-bottom: 10px;
    }
    
    /* Inputs */
    QLineEdit, QComboBox {
        background-color: #f7f9fc;
        border: 1px solid #e1e4e8;
        border-radius: 6px;
        padding: 8px;
        color: #333;
        font-size: 13px;
    }
    QLineEdit:focus {
        border: 1px solid #3b6998;
        background-color: white;
    }
    
    /* Action Buttons */
    QPushButton#btnSave {
        background-color: #4caf50; /* Green */
        color: white;
        font-weight: bold;
        border-radius: 6px;
        font-size: 14px;
    }
    QPushButton#btnSave:hover { background-color: #43a047; }
    
    QPushButton#btnCancel {
        background-color: #90a4ae; /* Grey */
        color: white;
        font-weight: bold;
        border-radius: 6px;
        font-size: 14px;
    }
    QPushButton#btnCancel:hover { background-color: #78909c; }

   </string>
  </property>
